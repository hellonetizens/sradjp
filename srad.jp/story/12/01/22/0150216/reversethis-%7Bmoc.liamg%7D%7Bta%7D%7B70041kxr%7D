<h4><a href="../../../../../comments.pl_ed987f08.html" id="comment_link_2085134" name="comment_link_2085134" onclick="return D2.setFocusComment(2085134)">雑感</a>
<span class="score" id="comment_score_2085134">(<a href="reversethis-%7Bmoc.liamg%7D%7Bta%7D%7B70041kxr%7D" onclick="getModalPrefs('modcommentlog', 'Moderation Comment Log', 2085134); return false">スコア:3</a>)</span></h4>
</div>
<div class="details">
