<span class="score" id="comment_score_1840942">(<a href="Unicode-6.0%E3%81%A7%E7%B5%B5%E6%96%87%E5%AD%97%E3%81%8C%E6%8E%A1%E7%94%A8%E3%81%95%E3%82%8C%E3%82%8B" onclick="getModalPrefs('modcommentlog', 'Moderation Comment Log', 1840942); return false">スコア:1</a>)</span></h4>
