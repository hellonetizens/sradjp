<span class="score" id="comment_score_2950991">(<a href="8.1%E3%81%8CSkylake%E6%90%AD%E8%BC%89%E3%83%87%E3%83%90%E3%82%A4%E3%82%B9%E3%82%92%E3%82%B5%E3%83%9D%E3%83%BC%E3%83%88%E3%81%99%E3%82%8B%E3%81%AE%E3%81%AF2017%E5%B9%B47%E6%9C%88%E3%81%BE%E3%81%A7" onclick="getModalPrefs('modcommentlog', 'Moderation Comment Log', 2950991); return false">スコア:1</a>)</span></h4>
