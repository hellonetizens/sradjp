<span class="score" id="comment_score_653336">(<a href="TCP%E3%81%AE%E9%95%B7%E8%B7%9D%E9%9B%A2%E9%AB%98%E9%80%9F%E9%80%9A%E4%BF%A1%E5%AE%9F%E9%A8%93%E3%80%817.21Gbps%E3%81%A7%E4%B8%96%E7%95%8C%E8%A8%98%E9%8C%B2%E3%82%92%E6%9B%B4%E6%96%B0" onclick="getModalPrefs('modcommentlog', 'Moderation Comment Log', 653336); return false">スコア:4</a>, 参考になる)</span></h4>
