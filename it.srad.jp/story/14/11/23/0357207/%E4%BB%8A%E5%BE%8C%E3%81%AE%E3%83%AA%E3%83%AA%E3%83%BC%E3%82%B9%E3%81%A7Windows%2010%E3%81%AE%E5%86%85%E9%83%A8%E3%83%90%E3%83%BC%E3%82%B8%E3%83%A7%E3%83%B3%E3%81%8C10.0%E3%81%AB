<span class="score" id="comment_score_2716121">(<a href="%E4%BB%8A%E5%BE%8C%E3%81%AE%E3%83%AA%E3%83%AA%E3%83%BC%E3%82%B9%E3%81%A7Windows%2010%E3%81%AE%E5%86%85%E9%83%A8%E3%83%90%E3%83%BC%E3%82%B8%E3%83%A7%E3%83%B3%E3%81%8C10.0%E3%81%AB" onclick="getModalPrefs('modcommentlog', 'Moderation Comment Log', 2716121); return false">スコア:3</a>, 興味深い)</span></h4>
