<span class="score" id="comment_score_2358697">(<a href="%E7%A6%8F%E5%B3%B6%E7%AC%AC%E4%B8%80%E5%8E%9F%E7%99%BA%E3%80%81%E5%9C%B0%E4%B8%8B%E8%B2%AF%E6%B0%B4%E6%A7%BDNo.3%E3%81%8B%E3%82%89%E3%82%82%E6%B1%9A%E6%9F%93%E6%B0%B4%E3%81%8C%E6%BC%8F%E5%87%BA" onclick="getModalPrefs('modcommentlog', 'Moderation Comment Log', 2358697); return false">スコア:5</a>, すばらしい洞察)</span></h4>
